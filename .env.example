# Massive.com data API credentials.
# Get a free-tier key from https://massive.com/ and copy this file to .env
# (which is gitignored). NEVER commit the actual values.
#
# Used by: scripts/explore_massive_flatfiles.py and any downstream loader.

# S3-compatible flat-files access (boto3)
MASSIVE_S3_ACCESS_KEY_ID=your-access-key-id-here
MASSIVE_S3_SECRET_ACCESS_KEY=your-secret-access-key-here
MASSIVE_S3_ENDPOINT_URL=https://files.massive.com

# REST API key (5 calls/min on free tier)
MASSIVE_REST_API_KEY=your-rest-api-key-here
